<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net7.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AssemblyName>vTools</AssemblyName>
    <Product>vTools</Product>
    <Title>vTools</Title>
    <RootNamespace>vTools</RootNamespace>
    <LangVersion>latest</LangVersion>
    <Deterministic>true</Deterministic>
    <Version>26.5.14.1319</Version>
    <InformationalVersion>26.5.14.1154</InformationalVersion>
    <AssemblyVersion>26.5.14.1319</AssemblyVersion>
    <FileVersion>26.5.14.1319</FileVersion>
    <!-- Fail fast when output files are locked (no retry loop). -->
    <CopyRetryCount>0</CopyRetryCount>
    <CopyRetryDelayMilliseconds>0</CopyRetryDelayMilliseconds>
    <!-- Enabled: successful Release builds auto-commit tracked version artifacts. -->
    <AutoCommitVersionOnRelease>true</AutoCommitVersionOnRelease>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.WindowsDesktop.App" />

    <Reference Include="RhinoCommon">
      <HintPath>$(ProgramFiles)\Rhino 8\System\RhinoCommon.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Eto">
      <HintPath>$(ProgramFiles)\Rhino 8\System\Eto.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Rhino.UI">
      <HintPath>$(ProgramFiles)\Rhino 8\System\Rhino.UI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Content Include="vTools.config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Create a timestamped snapshot of build outputs after every successful Release build. -->
  <Target Name="CreateReleaseBackup" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <BackupTimestamp>$([System.DateTime]::Now.ToString('yy.MM.dd.HHmmss'))</BackupTimestamp>
      <BackupOutputRoot>$(MSBuildProjectDirectory)\bin\Release\backups\$(BackupTimestamp)</BackupOutputRoot>
    </PropertyGroup>

    <ItemGroup>
      <BackupFiles Include="$(TargetDir)**\*.*" />
    </ItemGroup>

    <MakeDir Directories="$(BackupOutputRoot)" />
    <Copy
      SourceFiles="@(BackupFiles)"
      DestinationFolder="$(BackupOutputRoot)\%(RecursiveDir)"
      SkipUnchangedFiles="false" />

    <Message Importance="high" Text="vTools backup created: $(BackupOutputRoot)" />
  </Target>

  <!-- Commit updated version metadata and release plugin binary after successful Release builds. -->
  <Target Name="CommitReleaseVersion" AfterTargets="CreateReleaseBackup" Condition="'$(Configuration)' == 'Release' and '$(AutoCommitVersionOnRelease)' == 'true'">
    <PropertyGroup>
      <ShortTagVersion>$([System.Text.RegularExpressions.Regex]::Match('$(Version)', '^\d{2}\.\d{2}\.\d{2}').Value)</ShortTagVersion>
    </PropertyGroup>

    <Exec
      Command="git -C &quot;$(MSBuildProjectDirectory)&quot; add -A -- ."
      IgnoreExitCode="true" />

    <Exec
      Command="git -C &quot;$(MSBuildProjectDirectory)&quot; diff --cached --quiet -- ."
      IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="VersionCommitDiffExitCode" />
    </Exec>

    <Exec
      Command="git -C &quot;$(MSBuildProjectDirectory)&quot; diff --cached --quiet -- &quot;bin/Release/net7.0-windows/vTools.dll&quot;"
      IgnoreExitCode="true"
      Condition="'$(VersionCommitDiffExitCode)' != '0'">
      <Output TaskParameter="ExitCode" PropertyName="VersionDllDiffExitCode" />
    </Exec>

    <!-- If a pending message was written by Copilot before this build, use it directly. -->
    <PropertyGroup Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0'">
      <PendingMessageFile>$(MSBuildProjectDirectory)\.git\vtools-pending-message.txt</PendingMessageFile>
      <HasPendingMessage Condition="Exists('$(PendingMessageFile)')">true</HasPendingMessage>
    </PropertyGroup>

    <Copy
      SourceFiles="$(PendingMessageFile)"
      DestinationFiles="$(MSBuildProjectDirectory)\.git\vtools-autocommit-message.txt"
      Condition="'$(HasPendingMessage)' == 'true' and '$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0'"
      OverwriteReadOnlyFiles="true" />

    <Delete
      Files="$(PendingMessageFile)"
      Condition="'$(HasPendingMessage)' == 'true' and '$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0'" />

    <PropertyGroup Condition="'$(HasPendingMessage)' == 'true' and '$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0'">
      <VersionCommitMessageExitCode>0</VersionCommitMessageExitCode>
    </PropertyGroup>

    <!-- Fallback: auto-generate a placeholder message when no pending message exists. -->
    <Exec
      Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$repo='$(MSBuildProjectDirectory)'; $lines=@(git -C $repo diff --cached --name-status -- .); $changes=New-Object System.Collections.Generic.List[object]; foreach($line in $lines){ if([string]::IsNullOrWhiteSpace($line)){continue}; $parts=$line -split '\t+',2; if($parts.Count -lt 2){continue}; $changes.Add([pscustomobject]@{Status=$parts[0]; Path=$parts[1]}) }; function Get-Label([string]$name){ if($name -eq 'vTogglePerpGumball'){ return 'PerpGumbal' }; if($name.StartsWith('v') -and $name.Length -gt 1){ return $name.Substring(1) }; return $name }; function Build-LabelList([System.Collections.Generic.List[string]]$items){ if($items.Count -eq 0){ return '' }; $labels=New-Object System.Collections.Generic.List[string]; foreach($i in $items){ [void]$labels.Add((Get-Label $i)) }; if($labels.Count -le 2){ return ($labels -join ', ') }; return (($labels[0..1] -join ', ') + ', +' + ($labels.Count - 2) + ' more') }; $cmdAdds=New-Object System.Collections.Generic.List[string]; $cmdMods=New-Object System.Collections.Generic.List[string]; $hasReadme=$false; $hasBuildCfg=$false; $hasDll=$false; foreach($c in $changes){ $p=($c.Path -replace '\\','/'); if($p -eq 'README.md'){$hasReadme=$true}; if($p -eq 'vTools.csproj' -or $p -eq 'Properties/AssemblyInfo.cs'){$hasBuildCfg=$true}; if($p -eq 'bin/Release/net7.0-windows/vTools.dll'){$hasDll=$true}; if($p -like 'Commands/*.cs'){ $n=[System.IO.Path]::GetFileNameWithoutExtension($p); if($n -like 'v*'){ if($c.Status -like 'A*'){ if(-not $cmdAdds.Contains($n)){[void]$cmdAdds.Add($n)} } else { if(-not $cmdMods.Contains($n)){[void]$cmdMods.Add($n)} } } } }; $parts=New-Object System.Collections.Generic.List[string]; if($cmdAdds.Count -eq 1){ $parts.Add('add ' + (Get-Label $cmdAdds[0]) + ' command') } elseif($cmdAdds.Count -gt 1){ $parts.Add('add commands: ' + (Build-LabelList $cmdAdds)) }; if($cmdMods.Count -eq 1){ $label=Get-Label $cmdMods[0]; $parts.Add($label + ': update') } elseif($cmdMods.Count -gt 1){ $parts.Add('update: ' + (Build-LabelList $cmdMods)) }; if($hasReadme){ $parts.Add('docs: refresh command notes') }; if($hasBuildCfg -and $parts.Count -eq 0){ $parts.Add('build: sync version metadata') }; if($hasDll -and $parts.Count -eq 0){ $parts.Add('build: publish release binary') }; if($parts.Count -eq 0){ $parts.Add('maintenance: apply project updates') }; $summary=($parts -join '; '); $msg='$(Version): ' + $summary; Set-Content -Path (Join-Path $repo '.git\\vtools-autocommit-message.txt') -Value $msg -NoNewline -Encoding utf8&quot;"
      IgnoreExitCode="true"
      Condition="'$(HasPendingMessage)' != 'true' and '$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0'">
      <Output TaskParameter="ExitCode" PropertyName="VersionCommitMessageExitCode" />
    </Exec>

    <Exec
      Command="git -C &quot;$(MSBuildProjectDirectory)&quot; commit -F &quot;.git/vtools-autocommit-message.txt&quot;"
      IgnoreExitCode="true"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0' and '$(VersionCommitMessageExitCode)' == '0'">
      <Output TaskParameter="ExitCode" PropertyName="VersionCommitExitCode" />
    </Exec>

    <Exec
      Command="git -C &quot;$(MSBuildProjectDirectory)&quot; rev-parse -q --verify &quot;refs/tags/$(ShortTagVersion)&quot;"
      IgnoreExitCode="true"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionCommitExitCode)' == '0' and '$(ShortTagVersion)' != ''">
      <Output TaskParameter="ExitCode" PropertyName="ShortTagExistsExitCode" />
    </Exec>

    <Exec
      Command="git -C &quot;$(MSBuildProjectDirectory)&quot; tag &quot;$(ShortTagVersion)&quot;"
      IgnoreExitCode="true"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionCommitExitCode)' == '0' and '$(ShortTagVersion)' != '' and '$(ShortTagExistsExitCode)' != '0'">
      <Output TaskParameter="ExitCode" PropertyName="ShortTagCreateExitCode" />
    </Exec>

    <Message
      Importance="high"
      Text="vTools version commit created: $(Version)"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionCommitExitCode)' == '0'" />

    <Message
      Importance="high"
      Text="vTools short tag created: $(ShortTagVersion)"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionCommitExitCode)' == '0' and '$(ShortTagVersion)' != '' and '$(ShortTagExistsExitCode)' != '0' and '$(ShortTagCreateExitCode)' == '0'" />

    <Message
      Importance="high"
      Text="vTools short tag skipped (already exists): $(ShortTagVersion)"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionCommitExitCode)' == '0' and '$(ShortTagVersion)' != '' and '$(ShortTagExistsExitCode)' == '0'" />

    <Message
      Importance="high"
      Text="vTools short tag skipped (tag creation failed): $(ShortTagVersion)"
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionCommitExitCode)' == '0' and '$(ShortTagVersion)' != '' and '$(ShortTagExistsExitCode)' != '0' and '$(ShortTagCreateExitCode)' != '0'" />

    <Message
      Importance="high"
      Text="vTools version commit skipped (release DLL unchanged or locked)."
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' == '0'" />

    <Message
      Importance="high"
      Text="vTools version commit skipped (failed to build auto commit message)."
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0' and '$(VersionCommitMessageExitCode)' != '0'" />

    <Message
      Importance="high"
      Text="vTools version commit skipped (git commit failed; check git identity, branch, or repo state)."
      Condition="'$(VersionCommitDiffExitCode)' != '0' and '$(VersionDllDiffExitCode)' != '0' and '$(VersionCommitMessageExitCode)' == '0' and '$(VersionCommitExitCode)' != '0'" />

    <Message
      Importance="high"
      Text="vTools version commit skipped (no staged changes)."
      Condition="'$(VersionCommitDiffExitCode)' == '0'" />
  </Target>

</Project>
